{% comment %}
  Checkout Hold Gate (app embed).

  Prevents a practitioner who is on a PAYMENT order hold (an outstanding failed
  invoice) from reaching checkout, and shows the support message on the cart.

  This is the storefront UX layer. The un-bypassable server-side block is the
  cart.validations.generate.run Function (extensions/cart-checkout-validation),
  which blocks ORDER COMPLETION at checkout but cannot stop the buyer from
  navigating to /checkout or render a message on the cart. This embed closes
  that gap: for a logged-in customer it asks the app whether they're held
  (source of truth = live invoice state, via the app proxy), and if so it
  disables every checkout button/link and shows the message.

  Enabled once by the merchant under Theme editor → App embeds. Runs on every
  storefront page (cheap: one proxy call per session, cached), and acts wherever
  a checkout trigger appears — the cart page AND the cart drawer.
{% endcomment %}

{%- if customer -%}
<script>
(function () {
  "use strict";

  // App proxy subpath is fixed (shopify.app.toml [app_proxy].subpath). No
  // merchant-facing setting — keep the embed config-free.
  var PROXY_BASE = "wholesale-application";
  var STATUS_URL = "/apps/" + PROXY_BASE + "/api/storefront/order-hold";
  var CACHE_KEY = "ns_order_hold_status";
  var CACHE_TTL_MS = 30000; // re-check at most every 30s per session
  var FALLBACK_MESSAGE =
    "You have an outstanding invoice payment. Please pay your existing invoice before placing a new order. If you need assistance, please contact our support team.";

  // Selectors that trigger checkout across common themes (cart page + drawer).
  var CHECKOUT_SELECTOR = [
    '[name="checkout"]',
    '[name="goto_pp"]',
    'button[value="Checkout"]',
    '.cart__checkout-button',
    '.cart__checkout',
    '#checkout',
    '.shopify-payment-button',
    '[data-shopify="payment-button"]',
    'a[href$="/checkout"]',
    'a[href*="/checkout?"]'
  ].join(",");

  var state = { held: false, message: FALLBACK_MESSAGE, loaded: false };

  function readCache() {
    try {
      var raw = sessionStorage.getItem(CACHE_KEY);
      if (!raw) return null;
      var obj = JSON.parse(raw);
      if (!obj || (Date.now() - obj.t) > CACHE_TTL_MS) return null;
      return obj;
    } catch (e) { return null; }
  }
  function writeCache(held, message) {
    try {
      sessionStorage.setItem(CACHE_KEY, JSON.stringify({ held: held, message: message, t: Date.now() }));
    } catch (e) { /* ignore */ }
  }

  function isCheckoutTrigger(el) {
    if (!el || !el.closest) return null;
    return el.closest(CHECKOUT_SELECTOR);
  }

  // Capturing guards — block the action even if theme JS also binds it.
  function onClickCapture(e) {
    if (!state.held) return;
    var trigger = isCheckoutTrigger(e.target);
    if (!trigger) return;
    e.preventDefault();
    e.stopPropagation();
    if (e.stopImmediatePropagation) e.stopImmediatePropagation();
    ensureBanner();
  }
  function onSubmitCapture(e) {
    if (!state.held) return;
    var form = e.target;
    var action = (form && form.getAttribute) ? (form.getAttribute("action") || "") : "";
    // Cart form submits to /cart or /checkout; block when the submitter is a
    // checkout button, or the form posts straight to checkout.
    var submitter = e.submitter && isCheckoutTrigger(e.submitter);
    if (!submitter && action.indexOf("/checkout") === -1) return;
    e.preventDefault();
    e.stopPropagation();
    if (e.stopImmediatePropagation) e.stopImmediatePropagation();
    ensureBanner();
  }

  function disableTriggers() {
    if (!state.held) return;
    var nodes = document.querySelectorAll(CHECKOUT_SELECTOR);
    for (var i = 0; i < nodes.length; i++) {
      var n = nodes[i];
      if (n.dataset.nsHoldLocked === "1") continue;
      n.dataset.nsHoldLocked = "1";
      n.setAttribute("aria-disabled", "true");
      try { n.disabled = true; } catch (e) {}
      n.style.opacity = "0.5";
      n.style.pointerEvents = "none";
      n.style.cursor = "not-allowed";
    }
  }

  // The banner is position:FIXED with a max z-index and appended to <body>, so
  // it is immune to the theme's flex/grid/overflow clipping (which was hiding
  // earlier in-flow insertions). It's then positioned right below the checkout
  // button by tracking the button's viewport rect (re-tracked on scroll/resize
  // + cart re-renders). No dependency on the theme's container structure.
  function buildBanner() {
    var el = document.createElement("div");
    el.id = "ns-order-hold-banner";
    el.setAttribute("role", "alert");
    el.style.cssText =
      "position:fixed;z-index:2147483647;box-sizing:border-box;margin:0;" +
      "padding:14px 16px;border:1px solid #fecaca;background:#fef2f2;" +
      "color:#991b1b;border-radius:8px;font-size:15px;line-height:1.5;" +
      "font-family:inherit;text-align:left;box-shadow:0 4px 16px rgba(0,0,0,0.14);";
    el.textContent = state.message || FALLBACK_MESSAGE;
    return el;
  }

  // First VISIBLE checkout button/link (a theme can have hidden drawer copies).
  function findVisibleCheckout() {
    var nodes = document.querySelectorAll(CHECKOUT_SELECTOR);
    for (var i = 0; i < nodes.length; i++) {
      var r = nodes[i].getBoundingClientRect();
      if (r.width > 0 && r.height > 0) return nodes[i];
    }
    return null;
  }

  function positionBanner(banner) {
    var btn = findVisibleCheckout();
    if (btn) {
      var r = btn.getBoundingClientRect();
      var top = r.bottom + 8;
      // Keep it on-screen if the button is scrolled near the bottom edge.
      var maxTop = window.innerHeight - banner.offsetHeight - 8;
      if (top > maxTop) top = Math.max(8, maxTop);
      banner.style.top = top + "px";
      banner.style.left = r.left + "px";
      banner.style.width = Math.max(r.width, 260) + "px";
      banner.style.right = "auto";
      banner.style.bottom = "auto";
    } else {
      // No visible checkout button (e.g. drawer closed) — pin bottom-center.
      banner.style.top = "auto";
      banner.style.bottom = "16px";
      banner.style.left = "50%";
      banner.style.right = "auto";
      banner.style.width = "min(560px, calc(100% - 32px))";
      banner.style.transform = "translateX(-50%)";
    }
  }

  function ensureBanner() {
    if (!state.held) return;
    try {
      var banner = document.getElementById("ns-order-hold-banner");
      if (!banner) {
        banner = buildBanner();
        document.body.appendChild(banner);
      }
      positionBanner(banner);
    } catch (err) {
      if (window.console) console.warn("[ns-hold] banner failed:", err);
    }
  }

  function enforce() {
    if (!state.held) return;
    disableTriggers();
    ensureBanner();
  }

  function applyStatus(held, message) {
    state.held = !!held;
    state.message = message || FALLBACK_MESSAGE;
    state.loaded = true;
    if (state.held) enforce();
  }

  function fetchStatus() {
    var cached = readCache();
    if (cached) { applyStatus(cached.held, cached.message); return; }
    fetch(STATUS_URL, { headers: { "Accept": "application/json" }, credentials: "same-origin" })
      .then(function (r) { return r.ok ? r.json() : null; })
      .then(function (json) {
        // api.service wraps payload as { status, message, result }.
        var data = (json && json.result) ? json.result : (json || {});
        var held = !!data.held;
        var message = data.message || FALLBACK_MESSAGE;
        writeCache(held, message);
        applyStatus(held, message);
      })
      .catch(function () { /* fail open — never block on a network error */ });
  }

  // Capturing listeners installed once, up front — they no-op until held.
  document.addEventListener("click", onClickCapture, true);
  document.addEventListener("submit", onSubmitCapture, true);

  // Re-apply when the cart re-renders (drawer open, ajax cart update, etc.).
  var reapply = (function () {
    var scheduled = false;
    return function () {
      if (scheduled) return;
      scheduled = true;
      requestAnimationFrame(function () { scheduled = false; enforce(); });
    };
  })();
  ["cart:refresh", "cart:updated", "cart:change"].forEach(function (evt) {
    document.addEventListener(evt, reapply);
  });
  if (window.MutationObserver) {
    new MutationObserver(reapply).observe(document.documentElement, {
      childList: true, subtree: true
    });
  }

  // Keep the fixed banner tracked to the checkout button as the page scrolls
  // or resizes (reposition only — cheap, no DOM insert).
  function reposition() {
    if (!state.held) return;
    var banner = document.getElementById("ns-order-hold-banner");
    if (banner) positionBanner(banner);
  }
  window.addEventListener("scroll", reposition, { passive: true });
  window.addEventListener("resize", reposition);

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", fetchStatus);
  } else {
    fetchStatus();
  }
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Checkout Hold Gate",
  "target": "body",
  "settings": []
}
{% endschema %}
