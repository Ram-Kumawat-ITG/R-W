{% assign bundle_url = 'practitioner-portal-bundle.js' | asset_url %}
{% assign asset_base = bundle_url | split: 'practitioner-portal-bundle.js' | first %}

<script>
  window.__PORTAL_EXT_ASSET_BASE__ = {{ asset_base | json }};
</script>

{{ 'practitioner-portal-bundle.css' | asset_url | stylesheet_tag }}

{% comment %}
  Config is baked in (no merchant-facing settings): the app-proxy subpath must
  match shopify.app.toml [app_proxy].subpath, and the login/support values are
  app-owned, not per-merchant knobs. Update them here if they ever change.
{% endcomment %}
<div id="portal-root"
  data-proxy-base="wholesale-application"
  data-login-page-url="/account/login"
  data-support-email=""></div>

<script src="{{ 'practitioner-portal-bundle.js' | asset_url }}" type="module"></script>

{% schema %}
{
  "name": "Practitioner Portal",
  "target": "section",
  "settings": []
}
{% endschema %}
