{
  "name": "ns-retail",
  "private": true,
  "scripts": {
    "build": "react-router build",
    "build:signup": "npm --prefix signup-form run build",
    "build:practitioner-code": "npm --prefix practitioner-code-form run build",
    "build:client-portal": "npm --prefix client-portal run build",
    "sync:extension-app-url": "node scripts/sync-extension-app-url.js",
    "predev": "npm run sync:extension-app-url",
    "predeploy": "npm run build:signup && npm run build:practitioner-code && npm run build:client-portal && npm run sync:extension-app-url",
    "dev": "shopify app dev --graphiql-port=13458 --theme-app-extension-port=19293",
    "dev:local": "shopify app dev --config localhost --use-localhost --graphiql-port=13458 --theme-app-extension-port=19293",
    "config:link": "shopify app config link",
    "generate": "shopify app generate",
    "deploy": "shopify app deploy",
    "config:use": "shopify app config use",
    "seed:cdo": "node --env-file-if-exists=.env scripts/seed-cdo.js",
    "seed:cdo-apps": "node --env-file-if-exists=.env scripts/seed-cdo-applications.js",
    "seed:cdo-ref": "node --env-file-if-exists=.env scripts/seed-cdo-referral-customers.js",
    "seed:cdo-activity": "node --env-file-if-exists=.env scripts/seed-cdo-activity-aarav.js",
    "seed:cdo-orders": "node --env-file-if-exists=.env scripts/seed-cdo-patient-orders.js",
    "seed:cdo-parker": "node --env-file-if-exists=.env scripts/seed-cdo-parker-orders.js",
    "cdo:qbo-accounts": "node --env-file-if-exists=.env scripts/list-cdo-qbo-accounts.js",
    "migrate:practitioner-discounts": "node --experimental-loader ./scripts/extensionless-loader.mjs --env-file-if-exists=.env scripts/migrate-practitioner-discounts.js",
    "migrate:practitioner-discounts:apply": "node --experimental-loader ./scripts/extensionless-loader.mjs --env-file-if-exists=.env scripts/migrate-practitioner-discounts.js --apply",
    "env": "shopify app env",
    "start": "react-router-serve ./build/server/index.js",
    "docker-start": "npm run setup && npm run start",
    "setup": "prisma generate && prisma migrate deploy",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "shopify": "shopify",
    "prisma": "prisma",
    "graphql-codegen": "graphql-codegen",
    "vite": "vite",
    "typecheck": "react-router typegen && tsc --noEmit"
  },
  "type": "module",
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },
  "dependencies": {
    "@prisma/client": "^6.16.3",
    "@react-router/dev": "^7.12.0",
    "@react-router/fs-routes": "^7.12.0",
    "@react-router/node": "^7.12.0",
    "@react-router/serve": "^7.12.0",
    "@shopify/app-bridge-react": "^4.2.4",
    "@shopify/shopify-app-react-router": "^1.1.0",
    "@shopify/shopify-app-session-storage-mongodb": "^6.0.0",
    "@shopify/shopify-app-session-storage-prisma": "^9.0.0",
    "agenda": "^5.0.0",
    "cron-parser": "^3.5.0",
    "human-interval": "^2.0.1",
    "isbot": "^5.1.31",
    "mongoose": "^9.6.2",
    "nodemailer": "^9.0.3",
    "prisma": "^6.16.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.12.0",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "devDependencies": {
    "@shopify/api-codegen-preset": "^1.2.0",
    "@shopify/polaris-types": "1.0.1",
    "@types/eslint": "^9.6.1",
    "@types/node": "^22.18.8",
    "@types/react": "^18.3.25",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "graphql-config": "^5.1.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vite": "^6.3.6"
  },
  "workspaces": [
    "extensions/*"
  ],
  "trustedDependencies": [
    "@shopify/plugin-cloudflare"
  ],
  "overrides": {
    "p-map": "^4.0.0"
  },
  "author": "Itgeeks"
}
