{% comment %}
  Practitioner Code block — cart-page input for the referral / practitioner
  code. Grow-plan replacement for the checkout-ui-code extension.

  Zero merchant-facing settings by design — label / placeholder / button
  text all live in the React source (ns-retail/practitioner-code-form/)
  so a merchant can't accidentally break copy or wiring. The block just
  needs to be dropped onto the cart template; everything else is code.

  Loads the Vite-built practitioner-code-bundle.{js,css} and mounts the
  React app into #ns-practitioner-code-root.

  Backend URL is NOT here either — all fetches go through Shopify's app
  proxy at /apps/retail-signup/api/* (see ApiService.js). Same pattern
  the signup form already uses.

  Companion source: ns-retail/practitioner-code-form/
  Build (from ns-retail/): npm run build:practitioner-code
  (or just run shopify app deploy — the predeploy hook runs it automatically)

  Merchant places this block on the Cart template via the theme editor.
{% endcomment %}

{% assign bundle_url = 'practitioner-code-bundle.js' | asset_url %}
{% assign asset_base = bundle_url | split: 'practitioner-code-bundle.js' | first %}

<script>
  window.__PRACTITIONER_CODE_ASSET_BASE__ = {{ asset_base | json }};
  window.__PRACTITIONER_CODE_CONFIG__ = {
    customerId: {{ customer.id | json }},
    customerEmail: {{ customer.email | json }},
    shopDomain: {{ shop.permanent_domain | json }},
    initialCode: {{ cart.attributes.cdo_practitioner_code | default: '' | json }},
    initialPractitionerName: {{ cart.attributes.cdo_practitioner_name | default: '' | json }},
    initialDiscountPercent: {{ cart.attributes.cdo_practitioner_discount_percent | default: '' | json }}
  };
</script>

{{ 'practitioner-code-bundle.css' | asset_url | stylesheet_tag }}

<div id="ns-practitioner-code-root"></div>

<script src="{{ 'practitioner-code-bundle.js' | asset_url }}" type="module"></script>

{% schema %}
{
  "name": "Practitioner Code",
  "target": "section",
  "enabled_on": {
    "templates": ["cart"]
  },
  "settings": []
}
{% endschema %}
