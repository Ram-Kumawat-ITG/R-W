{% comment %}
  Practitioner Auto-Apply — HEADLESS APP EMBED (renders no visible UI).

  For a logged-in patient already attributed to a practitioner, this auto-applies
  their currently-assigned practitioner code to the cart session using Shopify's
  NATIVE /discount/<code> endpoint — so the discount lands as a normal applied
  discount and carries into checkout, with the buyer typing nothing and NO block
  placed on any page.

  APP EMBED (target: "body"): enabled once under Theme editor → App embeds →
  "Practitioner Auto-Apply". It is NOT a section block — the merchant never drops
  it on the Cart template. It renders site-wide but only ACTS once the cart has
  items (so browsing with an empty cart never triggers a redirect).

  Source of the code: the customer's `code:<code>` Shopify tag, which
  syncCustomerCodeTag keeps to exactly ONE entry = the LATEST code the
  practitioner assigned (portal "Assign discount code"). Read here in Liquid —
  no backend round-trip.

  Self-correcting: if the cart carries a code that is NOT the patient's
  currently-assigned one (e.g. left over after the practitioner reassigned or
  revoked it), that stale code is cleared and the assigned one re-applied — so a
  reassignment actually takes effect on an existing cart. Loop-safe: the
  sessionStorage guard is keyed on BOTH the assigned code AND the stale-code set,
  so each distinct situation gets exactly ONE apply attempt per tab session
  (set BEFORE the redirect, because a Function-based ORDER discount may not
  surface in /cart.json so "already applied" can't always be confirmed). A new
  assignment or a changed stale set gets its own single attempt.

  NOTE: this only runs when the customer still has a code:<code> tag. If a code
  is fully revoked (no assigned code / no tag) this block does not render, so a
  since-revoked code left on a cart is not force-cleared here — the checkout-time
  discount Function still declines it, so it can't actually discount the order.
{% endcomment %}

{%- assign cdo_code = '' -%}
{%- if customer -%}
  {%- for tag in customer.tags -%}
    {%- assign tag_down = tag | downcase -%}
    {%- if tag_down contains 'code:' -%}
      {%- assign cdo_code = tag | split: ':' | last | strip -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- if cdo_code != '' -%}
<script>
(function () {
  var code = {{ cdo_code | json }};
  if (!code) return;
  var lower = String(code).toLowerCase();

  fetch('/cart.json', { headers: { Accept: 'application/json' }, credentials: 'include' })
    .then(function (r) { return r.ok ? r.json() : null; })
    .then(function (cart) {
      if (!cart) return;

      // Only act once there's something to discount. If the cart is empty we
      // return WITHOUT recording an attempt, so it re-checks on the next
      // navigation and applies as soon as the buyer adds an item — covering
      // cart-drawer themes with no visit to the /cart page.
      var itemCount = typeof cart.item_count === 'number' ? cart.item_count : 0;
      if (itemCount <= 0) return;

      // Every discount code currently on the cart (normalized, applicable only).
      var flat = Array.isArray(cart.discount_codes) ? cart.discount_codes : [];
      var lvl = Array.isArray(cart.cart_level_discount_applications)
        ? cart.cart_level_discount_applications : [];
      var applied = flat.concat(lvl)
        .filter(function (dc) { return dc && dc.applicable !== false; })
        .map(function (dc) { return String((dc.code || dc.title) || '').toLowerCase(); })
        .filter(Boolean);

      var assignedApplied = applied.indexOf(lower) !== -1;
      // Any code on the cart that is NOT the patient's currently-assigned one —
      // e.g. a code left over after the practitioner reassigned/revoked it. The
      // practitioner discount is non-combinable, so a stale one must be cleared.
      var stale = applied.filter(function (c) { return c !== lower; });

      // Perfect state: exactly the assigned code is applied, nothing stale.
      if (assignedApplied && stale.length === 0) return;

      // Otherwise act: the assigned code isn't applied, or a stale/foreign code
      // is sitting on the cart. Guard is keyed on BOTH the assigned code AND the
      // stale set, so each distinct situation gets exactly ONE attempt per tab
      // session — loop-safe even if the clear is flaky or the assigned code
      // can't apply (declined / not surfaced in /cart.json). A NEW assignment or
      // a changed stale set produces a new key and gets its own single attempt.
      var key = 'cdo_auto_apply:' + lower + '|' + stale.slice().sort().join(',');
      try { if (sessionStorage.getItem(key) === '1') return; } catch (e) {}
      try { sessionStorage.setItem(key, '1'); } catch (e) {}

      var back = window.location.pathname + window.location.search;
      var go = function () {
        window.location.href =
          '/discount/' + encodeURIComponent(code) +
          '?redirect=' + encodeURIComponent(back);
      };
      // Clear any existing (stale / non-combinable) code first so the assigned
      // code takes effect, then apply. Best-effort — go regardless (applying a
      // non-combinable order discount also replaces a stale one on its own).
      fetch('/cart/update.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ discount: '' }),
      }).then(go, go);
    })
    .catch(function () {});
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Practitioner Auto-Apply",
  "target": "body",
  "settings": []
}
{% endschema %}
